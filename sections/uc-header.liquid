{%- style -%}
  #uc-header-{{ section.id }} { background:#000;color:#fff;font-family:var(--font-body-family),Arial,sans-serif; }
  #uc-header-{{ section.id }} .wrap { width:100%;max-width:1440px;margin:0 auto;padding:16px 28px;display:grid;grid-template-columns:128px 1fr auto;align-items:center;gap:28px; }
  #uc-header-{{ section.id }} .logo img { display:block;width:92px;height:auto; }
  #uc-header-{{ section.id }} .nav { display:flex;justify-content:center;gap:30px;font-size:15px;line-height:1; }
  #uc-header-{{ section.id }} .nav a { color:#fff;text-decoration:none;display:inline-flex;align-items:center;gap:5px;position:relative;padding:14px 0;white-space:nowrap; }
  #uc-header-{{ section.id }} .nav a::after{ content:"";position:absolute;left:0;right:0;bottom:4px;height:2px;background:#f4202a;transform:scaleX(0);transform-origin:left;transition:transform 160ms ease; }
  #uc-header-{{ section.id }} .nav a[aria-current='page']::after,
  #uc-header-{{ section.id }} .nav a:hover::after { transform:scaleX(1); }
  #uc-header-{{ section.id }} .chev{ width:8px;height:8px;border-right:1px solid currentColor;border-bottom:1px solid currentColor;transform:rotate(45deg) translateY(-2px);opacity:.75; }
  #uc-header-{{ section.id }} .icons { display:flex;gap:22px;align-items:center; }
  #uc-header-{{ section.id }} .icons a { color:#fff;text-decoration:none;line-height:1;display:flex; }
  #uc-header-{{ section.id }} .icons svg { width:21px;height:21px;display:block; }
  #uc-header-{{ section.id }} .menu-toggle{ display:none;color:#fff;background:transparent;border:0;padding:0;cursor:pointer; }
  #uc-header-{{ section.id }} .menu-toggle span{ display:block;width:22px;height:2px;background:currentColor;border-radius:999px;transition:transform 160ms ease,opacity 160ms ease; }
  #uc-header-{{ section.id }} .menu-toggle span + span{ margin-top:5px; }
  #uc-header-{{ section.id }} a:focus-visible,
  #uc-header-{{ section.id }} button:focus-visible{ outline:2px solid #f4202a;outline-offset:4px; }
  @media (max-width: 989px) {
    #uc-header-{{ section.id }} .wrap { grid-template-columns:1fr auto; }
    #uc-header-{{ section.id }} .icons{ grid-column:2;grid-row:1;justify-self:end; }
    #uc-header-{{ section.id }} .nav { grid-column:1 / -1;justify-content:flex-start;overflow-x:auto;gap:22px;padding-bottom:4px;scrollbar-width:none; }
    #uc-header-{{ section.id }} .nav::-webkit-scrollbar{ display:none; }
  }
  @media (max-width: 749px) {
    #uc-header-{{ section.id }} .wrap { grid-template-columns:auto 1fr auto;padding-left:16px;padding-right:16px;gap:14px; }
    #uc-header-{{ section.id }} .logo img { width:78px; }
    #uc-header-{{ section.id }} .icons { grid-column:2;grid-row:1;justify-self:end;gap:14px;font-size:18px; }
    #uc-header-{{ section.id }} .menu-toggle{ grid-column:3;grid-row:1;display:inline-flex;width:40px;height:40px;align-items:center;justify-content:center;flex-direction:column; }
    #uc-header-{{ section.id }} .nav { display:none;grid-column:1 / -1;flex-direction:column;align-items:stretch;gap:0;overflow:visible;padding:10px 0 2px;border-top:1px solid rgba(255,255,255,.14);font-size:14px; }
    #uc-header-{{ section.id }}.is-menu-open .nav{ display:flex; }
    #uc-header-{{ section.id }} .nav a{ justify-content:space-between;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.1); }
    #uc-header-{{ section.id }} .nav a::after{ display:none; }
    #uc-header-{{ section.id }} .chev{ margin-left:auto; }
    #uc-header-{{ section.id }} .menu-toggle[aria-expanded='true'] span:first-child{ transform:translateY(7px) rotate(45deg); }
    #uc-header-{{ section.id }} .menu-toggle[aria-expanded='true'] span:nth-child(2){ opacity:0; }
    #uc-header-{{ section.id }} .menu-toggle[aria-expanded='true'] span:last-child{ transform:translateY(-7px) rotate(-45deg); }
  }
{%- endstyle -%}

<header id="uc-header-{{ section.id }}" data-uc-mobile-header>
  <div class="wrap">
    <a class="logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      <img src="{{ 'uc-logo.webp' | asset_url }}" alt="{{ shop.name | escape }}" loading="eager" width="1082" height="623">
    </a>
    <button class="menu-toggle" type="button" aria-controls="uc-header-nav-{{ section.id }}" aria-expanded="false" aria-label="Toggle navigation" data-uc-menu-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <nav id="uc-header-nav-{{ section.id }}" class="nav" aria-label="Main navigation">
      {%- for block in section.blocks -%}
        {%- assign has_menu_cue = false -%}
        {%- if block.settings.label contains 'Collection' or block.settings.label contains 'Custom' or block.settings.label contains 'Signage' -%}
          {%- assign has_menu_cue = true -%}
        {%- endif -%}
        <a href="{{ block.settings.link | default: routes.root_url }}" {% if forloop.first %}aria-current="page"{% endif %} {{ block.shopify_attributes }}>
          <span>{{ block.settings.label }}</span>
          {%- if has_menu_cue -%}<span class="chev" aria-hidden="true"></span>{%- endif -%}
        </a>
      {%- endfor -%}
    </nav>
    <div class="icons" aria-label="Store tools">
      <a href="{{ routes.search_url }}" aria-label="Search">{{ 'icon-search.svg' | inline_asset_content }}</a>
      <a href="{{ routes.account_url }}" aria-label="Account">{{ 'icon-account.svg' | inline_asset_content }}</a>
      <a href="{{ routes.cart_url }}" aria-label="Cart">{{ 'icon-cart.svg' | inline_asset_content }}</a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "UC Header",
  "blocks": [
    {
      "type": "link",
      "name": "Navigation link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Home" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UC Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Home" } },
        { "type": "link", "settings": { "label": "Collection" } },
        { "type": "link", "settings": { "label": "Custom Wall Art" } },
        { "type": "link", "settings": { "label": "Custom Apparel" } },
        { "type": "link", "settings": { "label": "Bulk Order" } },
        { "type": "link", "settings": { "label": "Signage & Branding" } }
      ]
    }
  ]
}
{% endschema %}
