{%- comment -%}
  Urban Customz — Top Utility Bar
  Drop into Dawn theme `sections/` and add via theme editor, or place above header in layout/theme.liquid.
{%- endcomment -%}

{%- style -%}
  #uc-utility-{{ section.id }}{
    background:{{ section.settings.bg }};
    color:{{ section.settings.text_color }};
    font-size:13px;
    font-family:'Poppins',var(--font-body-family),sans-serif;
  }
  #uc-utility-{{ section.id }} .uc-utility-inner{ max-width:var(--uc-page-max);margin:0 auto;padding:8px var(--uc-page-pad);display:flex;align-items:center;justify-content:flex-end;gap:72px; }
  #uc-utility-{{ section.id }} .uc-util{ display:flex;align-items:center;gap:10px; }
  #uc-utility-{{ section.id }} .uc-util-ic{ width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center; }
  #uc-utility-{{ section.id }} .uc-util-ic svg{ width:16px;height:16px;stroke:currentColor; }
  #uc-utility-{{ section.id }} .uc-util b{ font-weight:600; }
  #uc-utility-{{ section.id }} .uc-util small{ font-size:11px;color:{{ section.settings.accent }}; }
  @media (max-width:749px){ #uc-utility-{{ section.id }} .uc-utility-inner{ justify-content:center;gap:18px;flex-wrap:wrap;padding-top:10px;padding-bottom:10px; } }
{%- endstyle -%}

<div id="uc-utility-{{ section.id }}">
  <div class="uc-utility-inner">
    <a href="tel:{{ section.settings.phone | strip }}" class="uc-util" style="color:inherit;text-decoration:none">
      <span class="uc-util-ic" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 12a8 8 0 0 1 16 0"/><path d="M4 12v3a2 2 0 0 0 2 2h1v-7H6a2 2 0 0 0-2 2Z"/><path d="M20 12v3a2 2 0 0 1-2 2h-1v-7h1a2 2 0 0 1 2 2Z"/><path d="M14 19h1a3 3 0 0 0 3-3"/></svg>
      </span>
      <span><b>{{ section.settings.phone }}</b><br><small>● {{ section.settings.phone_label }}</small></span>
    </a>
    <a href="{{ section.settings.chat_url }}" class="uc-util" style="color:inherit;text-decoration:none">
      <span class="uc-util-ic" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12a7 7 0 0 1-7 7H8l-5 3 1.6-5.4A7 7 0 1 1 21 12Z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
      </span>
      <span><b>{{ section.settings.chat_title }}</b><br><small>● {{ section.settings.chat_label }}</small></span>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "UC Utility Bar",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "accent", "label": "Status accent", "default": "#8fd18f" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 (888) 307-4622" },
    { "type": "text", "id": "phone_label", "label": "Phone label", "default": "Wait time: 0min" },
    { "type": "text", "id": "chat_title", "label": "Chat title", "default": "Live Chat Now" },
    { "type": "text", "id": "chat_label", "label": "Chat label", "default": "Chat with an expert" },
    { "type": "url", "id": "chat_url", "label": "Chat link" }
  ],
  "presets": [{ "name": "UC Utility Bar" }]
}
{% endschema %}
