{%- style -%}
  #uc-footer-{{ section.id }} { background:#000;color:#fff;font-family:var(--font-body-family),Arial,sans-serif;margin-top:54px; }
  #uc-footer-{{ section.id }} .wrap { max-width:var(--uc-page-max);margin:0 auto;padding:58px var(--uc-page-pad) 28px;display:grid;grid-template-columns:1.25fr .78fr .78fr 1.35fr;gap:44px; }
  #uc-footer-{{ section.id }} img { width:138px;height:auto;margin-bottom:18px; }
  #uc-footer-{{ section.id }} p, #uc-footer-{{ section.id }} a, #uc-footer-{{ section.id }} label { color:#fff;font-size:13px;line-height:1.8;text-decoration:none; }
  #uc-footer-{{ section.id }} p{ color:rgba(255,255,255,.86); }
  #uc-footer-{{ section.id }} h3 { color:#fff;font-size:18px;margin:0 0 16px;font-weight:800; }
  #uc-footer-{{ section.id }} ul { list-style:none;margin:0;padding:0; }
  #uc-footer-{{ section.id }} li + li{ margin-top:4px; }
  #uc-footer-{{ section.id }} a:hover{ color:#f4202a; }
  #uc-footer-{{ section.id }} input { width:100%;height:42px;border:1px solid #777;border-radius:8px;background:#000;color:#fff;padding:0 14px; }
  #uc-footer-{{ section.id }} button { height:42px;border:0;border-radius:8px;background:#f4202a;color:#fff;padding:0 34px;font-size:16px;cursor:pointer; }
  #uc-footer-{{ section.id }} button:hover{ background:#ff3340; }
  #uc-footer-{{ section.id }} .form { display:grid;grid-template-columns:1fr 150px;gap:14px;margin-top:10px;align-items:end; }
  #uc-footer-{{ section.id }} .email-field{ min-width:0; }
  #uc-footer-{{ section.id }} .field-label{ display:block;margin-bottom:4px;font-weight:600;line-height:1.2; }
  /* HubSpot embedded form — match the dark footer */
  #uc-footer-{{ section.id }} .hs-form-frame{ margin-top:10px; }
  #uc-footer-{{ section.id }} .hs-form-frame input[type=email],
  #uc-footer-{{ section.id }} .hs-form-frame input[type=text]{ width:100%;height:42px;border:1px solid #777;border-radius:8px;background:#000;color:#fff;padding:0 14px;box-sizing:border-box; }
  #uc-footer-{{ section.id }} .hs-form-frame label{ font-weight:600;line-height:1.2; }
  #uc-footer-{{ section.id }} .hs-form-frame .hs-button,
  #uc-footer-{{ section.id }} .hs-form-frame input[type=submit]{ height:42px;border:0;border-radius:8px;background:#f4202a;color:#fff;padding:0 34px;font-size:16px;cursor:pointer;margin-top:12px; }
  #uc-footer-{{ section.id }} .hs-form-frame .hs-button:hover,
  #uc-footer-{{ section.id }} .hs-form-frame input[type=submit]:hover{ background:#ff3340; }
  #uc-footer-{{ section.id }} .hs-form-frame .hs-error-msg,
  #uc-footer-{{ section.id }} .hs-form-frame .hs-error-msgs label{ color:#ff8a90;font-weight:400; }
  #uc-footer-{{ section.id }} .contact { margin-top:22px;display:grid;gap:10px; }
  #uc-footer-{{ section.id }} .contact a{ display:flex;align-items:center;gap:10px;line-height:1.3; }
  #uc-footer-{{ section.id }} .contact svg{ width:22px;height:22px;stroke:#f4202a;flex:0 0 auto; }
  #uc-footer-{{ section.id }} .social { display:flex;gap:24px;margin-top:22px;color:#f4202a; }
  #uc-footer-{{ section.id }} .social a { color:#f4202a;display:flex; }
  #uc-footer-{{ section.id }} .social svg { width:22px;height:22px;display:block; }
  #uc-footer-{{ section.id }} .bottom { border-top:1px solid rgba(255,255,255,.16);max-width:var(--uc-page-max);margin:0 auto;padding:12px var(--uc-page-pad) 18px;color:#aaa;font-size:11px; }
  @media (max-width: 989px) { #uc-footer-{{ section.id }} .wrap { grid-template-columns:1fr 1fr; } }
  @media (max-width: 749px) { #uc-footer-{{ section.id }} .wrap { grid-template-columns:1fr;gap:28px; } #uc-footer-{{ section.id }} .form { grid-template-columns:1fr; } }
{%- endstyle -%}

<footer id="uc-footer-{{ section.id }}">
  <div class="wrap">
    <div>
      <img src="{{ 'uc-logo.webp' | asset_url }}" alt="{{ shop.name | escape }}" width="1082" height="623">
      <p>The ultimate destination for urban wall art, posters, and custom apparel. Together, let's build your vibe with diverse, high-quality offerings.</p>
      <div class="contact">
        <a href="tel:+18883074622">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L8 9.5a16 16 0 0 0 6.5 6.5l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2Z"/></svg>
          <span>+1 (888) 307-4622</span>
        </a>
        <a href="mailto:info@urbancustomz.com">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="m22 6-10 7L2 6"/></svg>
          <span>info@urbancustomz.com</span>
        </a>
      </div>
    </div>
    <div>
      <h3>Quick links</h3>
      <ul>
        <li><a href="{{ routes.search_url }}">Search</a></li>
        <li><a href="/pages/about-us">About us</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/locations">Locations</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/blogs/news">Blog</a></li>
        <li><a href="{{ routes.collections_url }}/halloween">Halloween</a></li>
        <li><a href="{{ routes.collections_url }}/ugly-christmas">Ugly Christmas</a></li>
        <li><a href="{{ routes.collections_url }}/sweaters">Sweaters</a></li>
      </ul>
    </div>
    <div>
      <h3>Policies</h3>
      <ul>
        <li><a href="/policies/terms-of-service">Terms and Services</a></li>
        <li><a href="/policies/refund-policy">Refund Policy</a></li>
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
      </ul>
    </div>
    <div>
      <h3>Subscribe to our emails</h3>
      <p>Sign up to receive Urban Customz emails and get first dibs on new arrivals, sales, exclusive content, events and more.</p>
      {%- if section.settings.hubspot_portal_id != blank and section.settings.hubspot_form_id != blank -%}
        <div class="hs-form-frame"
             data-region="{{ section.settings.hubspot_region | default: 'na1' }}"
             data-form-id="{{ section.settings.hubspot_form_id }}"
             data-portal-id="{{ section.settings.hubspot_portal_id }}"></div>
        <script defer src="https://js.hsforms.net/forms/embed/{{ section.settings.hubspot_portal_id }}.js"></script>
      {%- else -%}
        <form method="post" action="/contact#contact_form" accept-charset="UTF-8" class="form">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <div class="email-field">
            <label class="field-label" for="uc-footer-email-{{ section.id }}">Email</label>
            <input id="uc-footer-email-{{ section.id }}" type="email" name="contact[email]" placeholder="Email">
          </div>
          <button type="submit">SEND</button>
        </form>
      {%- endif -%}
      <div class="social" aria-label="Social links">
        <a href="https://www.facebook.com/" aria-label="Facebook">{{ 'icon-facebook.svg' | inline_asset_content }}</a>
        <a href="https://www.instagram.com/" aria-label="Instagram">{{ 'icon-instagram.svg' | inline_asset_content }}</a>
        <a href="https://www.tiktok.com/" aria-label="TikTok">{{ 'icon-tiktok.svg' | inline_asset_content }}</a>
      </div>
    </div>
  </div>
  <div class="bottom">Urban Customz demo theme for Shopify Dawn.</div>
</footer>

{% schema %}
{
  "name": "UC Footer",
  "settings": [
    { "type": "header", "content": "HubSpot newsletter form" },
    { "type": "paragraph", "content": "Set all three IDs to replace the default email form with an embedded HubSpot form. Leave blank to keep the native Shopify form." },
    { "type": "text", "id": "hubspot_portal_id", "label": "HubSpot Portal ID" },
    { "type": "text", "id": "hubspot_form_id", "label": "HubSpot Form ID" },
    { "type": "text", "id": "hubspot_region", "label": "HubSpot region", "default": "na1" }
  ],
  "presets": [{ "name": "UC Footer" }]
}
{% endschema %}
