{%- comment -%} Urban Customz — Why Choose Us (two annotated feature images) {%- endcomment -%}

{%- style -%}
  #uc-why-{{ section.id }}{ max-width:1500px;margin:60px auto 32px;padding:0 48px;font-family:'Poppins',var(--font-body-family),sans-serif; }
  #uc-why-{{ section.id }} h2{ font-size:34px;font-weight:800;margin:0; }
  #uc-why-{{ section.id }} .lead{ color:#6b6b6b;font-size:15px;margin-top:10px;max-width:760px; }
  #uc-why-{{ section.id }} .cols{ display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px; }
  #uc-why-{{ section.id }} .media{ aspect-ratio:1.3/1;border-radius:10px;overflow:hidden; }
  #uc-why-{{ section.id }} .media img,
  #uc-why-{{ section.id }} .media svg{ width:100%;height:100%;object-fit:contain;background:#f6f6f6; }
  #uc-why-{{ section.id }} .lbl{ text-align:center;font-weight:700;font-size:20px;color:#888;margin-top:18px; }
  @media (max-width:749px){ #uc-why-{{ section.id }} .cols{ grid-template-columns:1fr;gap:28px; } }
{%- endstyle -%}

<div id="uc-why-{{ section.id }}">
  <h2>{{ section.settings.heading }}</h2>
  <div class="lead">{{ section.settings.body }}</div>
  <div class="cols">
    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        <div class="media">
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {%- assign fallback_images = 'uc-why-wall-art.webp|uc-why-apparel.webp' | split: '|' -%}
            {%- assign fallback_image = fallback_images[forloop.index0] -%}
            <img src="{{ fallback_image | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="616" height="387">
          {%- endif -%}
        </div>
        <div class="lbl">{{ block.settings.label }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "UC Why Choose Us",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Choose Us?" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "No outsourcing. No shortcuts. Just premium Canadian craftsmanship applied to both your walls and your wardrobe." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Annotated image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Wall Art" }
      ]
    }
  ],
  "presets": [{
    "name": "UC Why Choose Us",
    "blocks": [
      { "type": "feature", "settings": { "label": "Wall Art" } },
      { "type": "feature", "settings": { "label": "Apparel" } }
    ]
  }]
}
{% endschema %}
