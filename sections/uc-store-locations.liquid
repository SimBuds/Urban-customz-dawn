{%- comment -%} Urban Customz — Store Locations {%- endcomment -%}

{%- style -%}
  #uc-loc-{{ section.id }}{ max-width:1500px;margin:60px auto;padding:0 48px;text-align:center;font-family:'Poppins',var(--font-body-family),sans-serif; }
  #uc-loc-{{ section.id }} h2{ font-size:30px;font-weight:800;color:#555;margin:0; }
  #uc-loc-{{ section.id }} h2 .hl{ color:#ff2222; }
  #uc-loc-{{ section.id }} .sub{ color:#5a78c0;font-size:12px;font-weight:600;margin:14px 0 28px; }
  #uc-loc-{{ section.id }} .grid{ display:grid;grid-template-columns:repeat({{ section.blocks.size | at_least: 1 }},1fr);gap:24px; }
  #uc-loc-{{ section.id }} .loc{ aspect-ratio:1/1;border-radius:6px;overflow:hidden;background:#222;display:block; }
  #uc-loc-{{ section.id }} .loc img,
  #uc-loc-{{ section.id }} .loc svg{ width:100%;height:100%;object-fit:cover; }
  @media (max-width:749px){ #uc-loc-{{ section.id }} .grid{ grid-template-columns:1fr;} }
{%- endstyle -%}

<div id="uc-loc-{{ section.id }}">
  <h2>{{ section.settings.heading }}</h2>
  <div class="sub">{{ section.settings.subheading }}</div>
  <div class="grid">
    {%- for block in section.blocks -%}
      <a class="loc" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {%- assign fallback_images = 'uc-location-1.webp|uc-location-2.webp|uc-location-3.webp' | split: '|' -%}
          {%- assign fallback_image = fallback_images[forloop.index0] -%}
          <img src="{{ fallback_image | asset_url }}" alt="Urban Customz location {{ forloop.index }}" loading="lazy" width="756" height="826">
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "UC Store Locations",
  "settings": [
    { "type": "html", "id": "heading", "label": "Heading (use <span class='hl'> for red)", "default": "We Are Not Just An <span class='hl'>Online</span> Store." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Some of our locations" }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Storefront image" },
        { "type": "url", "id": "link", "label": "Link (map / page)" }
      ]
    }
  ],
  "presets": [{
    "name": "UC Store Locations",
    "blocks": [ { "type": "location" }, { "type": "location" }, { "type": "location" } ]
  }]
}
{% endschema %}
